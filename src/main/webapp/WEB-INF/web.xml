<?xml version="1.0" encoding="UTF-8"?>
<web-app version="6.0" xmlns="https://jakarta.ee/xml/ns/jakartaee" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="https://jakarta.ee/xml/ns/jakartaee https://jakarta.ee/xml/ns/jakartaee/web-app_6_0.xsd">
    <servlet>
        <servlet-name>RegisterServlet</servlet-name>
        <servlet-class>com.bakeryzone.controller.auth.RegisterServlet</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>LoginServlet</servlet-name>
        <servlet-class>com.bakeryzone.controller.auth.LoginServlet</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>VerifyOtpServlet</servlet-name>
        <servlet-class>com.bakeryzone.controller.auth.VerifyOtpServlet</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>ForgotPasswordServlet</servlet-name>
        <servlet-class>com.bakeryzone.controller.auth.ForgotPasswordServlet</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>VerifyForgotOtpServlet</servlet-name>
        <servlet-class>com.bakeryzone.controller.auth.VerifyForgotOtpServlet</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>ResetPasswordServlet</servlet-name>
        <servlet-class>com.bakeryzone.controller.auth.ResetPasswordServlet</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>LogoutServlet</servlet-name>
        <servlet-class>com.bakeryzone.controller.auth.LogoutServlet</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>HomeServlet</servlet-name>
        <servlet-class>com.bakeryzone.controller.auth.HomeServlet</servlet-class>
    </servlet>
    <filter>
        <filter-name>AuthorizationFilter</filter-name>
        <filter-class>com.bakeryzone.controller.auth.AuthorizationFilter</filter-class>
    </filter>
    <filter>
        <filter-name>CharacterEncodingFilter</filter-name>
        <filter-class>org.apache.catalina.filters.SetCharacterEncodingFilter</filter-class>
        <init-param>
            <param-name>encoding</param-name>
            <param-value>UTF-8</param-value>
        </init-param>
        <init-param>
            <param-name>ignore</param-name>
            <param-value>true</param-value>
        </init-param>
    </filter>
    <filter-mapping>
        <filter-name>CharacterEncodingFilter</filter-name>
        <url-pattern>/*</url-pattern>
    </filter-mapping>
    <servlet>
        <servlet-name>CustomerCheckoutServlet</servlet-name>
        <servlet-class>com.bakeryzone.controller.customer.CustomerCheckoutServlet</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>RolePermissionServlet</servlet-name>
        <servlet-class>com.bakeryzone.controller.admin.RolePermissionServlet</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>MembershipController</servlet-name>
        <servlet-class>com.bakeryzone.controller.customer.MembershipController</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>RewardsController</servlet-name>
        <servlet-class>com.bakeryzone.controller.customer.RewardsController</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>RegisterServlet</servlet-name>
        <url-pattern>/register</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>LoginServlet</servlet-name>
        <url-pattern>/login</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>VerifyOtpServlet</servlet-name>
        <url-pattern>/verify-otp</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>ForgotPasswordServlet</servlet-name>
        <url-pattern>/forgot-password</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>VerifyForgotOtpServlet</servlet-name>
        <url-pattern>/verify-forgot-otp</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>ResetPasswordServlet</servlet-name>
        <url-pattern>/reset-password</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>LogoutServlet</servlet-name>
        <url-pattern>/logout</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>HomeServlet</servlet-name>
        <url-pattern>/home</url-pattern>
    </servlet-mapping>
    <filter-mapping>
        <filter-name>AuthorizationFilter</filter-name>
        <url-pattern>/admin/*</url-pattern>
        <dispatcher>REQUEST</dispatcher>
    </filter-mapping>
    <filter-mapping>
        <filter-name>AuthorizationFilter</filter-name>
        <url-pattern>/staff</url-pattern>
        <dispatcher>REQUEST</dispatcher>
    </filter-mapping>
    <!-- NOTE: /customer filter mapping removed. Customer JSPs are never accessed
         directly by clients — they are always reached via internal servlet forwards
         (e.g. CustomCakeServlet → /customer/customCakeStudio.jsp). Keeping this
         mapping caused the AuthorizationFilter to intercept internal FORWARDs and
         loop: forward → filter → no-permission → home.jsp forward → filter → ... -->
    <servlet-mapping>
        <servlet-name>CustomerCheckoutServlet</servlet-name>
        <url-pattern>/checkout</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>RolePermissionServlet</servlet-name>
        <url-pattern>/admin/role-permissions</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>MembershipController</servlet-name>
        <url-pattern>/membership</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>RewardsController</servlet-name>
        <url-pattern>/rewards</url-pattern>
    </servlet-mapping>
    <servlet>
        <servlet-name>CustomCakeServlet</servlet-name>
        <servlet-class>com.bakeryzone.controller.customer.CustomCakeServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>CustomCakeServlet</servlet-name>
        <url-pattern>/custom-cake</url-pattern>
    </servlet-mapping>
    <session-config>
        <session-timeout>30</session-timeout>
    </session-config>
</web-app>
